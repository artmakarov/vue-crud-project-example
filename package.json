{
  "name": "vue-crud-project-example",
  "version": "0.1.0",
  "author": {
    "name": "Artem Makarov",
    "email": "am.work.acc@gmail.com"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b --noEmit",
    "lint:check": "eslint .",
    "lint": "eslint . --fix",
    "format:check": "prettier src/ --check",
    "format": "prettier src/ --write",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^2.3.1",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.2",
    "prettier": "^3.8.2",
    "typescript": "~5.7.3",
    "vite": "^6.4.2",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "npm run lint",
      "npm run format"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
